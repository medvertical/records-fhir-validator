{
  "name": "records-fhir-validator-repo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/medvertical/records-fhir-validator.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/validation-types",
    "packages/validator"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "pack:dry": "npm run pack:dry --workspace @records-fhir/validation-types && npm run pack:dry --workspace @records-fhir/validator",
    "oss:audit-validator": "node scripts/oss/audit-validator-boundary.mjs",
    "oss:audit-validator:tests": "node scripts/oss/audit-validator-boundary.mjs --include-tests",
    "oss:smoke-validator": "node scripts/oss/smoke-validator-package.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  }
}
